rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== 辅助函数 ==========
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() && getUserDoc().data.role == "admin";
    }

    function isEmployer() {
      return isAuthenticated() && getUserDoc().data.role == "employer";
    }

    function isSeeker() {
      return isAuthenticated() && getUserDoc().data.role == "seeker";
    }

    function validUserCreate() {
      return request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ["seeker", "employer", "admin"]
        && request.resource.data.createdAt == request.time;
    }

    function validJobUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'title','description','requirements','responsibilities',
        'locationType','jobType','category','skillsRequired','salary',
        'status','updatedAt','expiresAt','featured','contact_mode',
        'contact_platform','contact_label','contact_link','country','city'
      ]);
    }

    // ========== users ==========
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && validUserCreate();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ========== profiles ==========
    match /profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
      allow delete: if isAdmin();
    }

    // ========== jobs ==========
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isEmployer() || isAdmin();
      allow update: if (isEmployer() && resource.data.employerId == request.auth.uid && validJobUpdate()) || isAdmin();
      allow delete: if (isEmployer() && resource.data.employerId == request.auth.uid) || isAdmin();
    }

    // ========== applications ==========
    match /applications/{applicationId} {
      allow read: if isAuthenticated() &&
        (resource.data.seekerId == request.auth.uid ||
         resource.data.employerId == request.auth.uid ||
         isAdmin());
      allow create: if isSeeker() && request.resource.data.seekerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.employerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ========== conversations ==========
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    // ========== messages (subcollection) ==========
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      allow update, delete: if isAdmin();
    }

    // ========== saved_jobs ==========
    match /saved_jobs/{savedJobId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ========== notifications (subcollection) ==========
    match /users/{uid}/notifications/{notificationId} {
      allow read: if isOwner(uid);
      allow create, update, delete: if isOwner(uid) || isAdmin();
    }

    // ========== reports ==========
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========== system/config (只读运营配置) ==========
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
