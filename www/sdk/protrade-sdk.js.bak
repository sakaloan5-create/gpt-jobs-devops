/**
 * ProTrade Remote Control SDK
 * 用于马甲包App远程控制
 */

class ProTradeSDK {
  constructor(config = {}) {
    this.apiUrl = config.apiUrl || this.detectApiUrl();
    this.deviceId = this.getDeviceId();
    this.currentMode = 'fitness';
    this.pollingInterval = null;
    this.config = null;
    
    this.defaultConfig = {
      coverEnabled: true,
      tradingEnabled: false,
      secretCode: 'PRO2024',
      activationMethod: 'both'
    };
  }
  
  detectApiUrl() {
    // ⚠️ 部署后修改：替换为你的 Vercel 地址
    // 示例: https://protrade-admin-xxxx.vercel.app/api
    const YOUR_API_URL = 'https://YOUR_VERCEL_URL.vercel.app/api';
    
    if (window.location.hostname === 'localhost') {
      return 'http://localhost:3000/api';
    }
    return YOUR_API_URL;
  }
  
  getDeviceId() {
    let deviceId = localStorage.getItem('pt_device_id');
    if (!deviceId) {
      deviceId = 'D' + Math.random().toString(36).substr(2, 9).toUpperCase();
      localStorage.setItem('pt_device_id', deviceId);
    }
    return deviceId;
  }
  
  async init() {
    try {
      await this.heartbeat();
      this.startPolling();
      console.log('ProTrade SDK initialized');
      return this.config || this.defaultConfig;
    } catch (error) {
      console.error('SDK init failed:', error);
      return this.defaultConfig;
    }
  }
  
  // 🔴 发送心跳 - 关键函数，接收强制切换指令
  async heartbeat() {
    try {
      const deviceInfo = {
        model: navigator.platform,
        os: navigator.userAgent,
        version: '1.0.0',
        screenMode: this.currentMode,
        timestamp: new Date().toISOString()
      };
      
      const response = await fetch(`${this.apiUrl}/device/heartbeat`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Device-ID': this.deviceId
        },
        body: JSON.stringify(deviceInfo)
      });
      
      const data = await response.json();
      
      if (data.config) {
        this.config = { ...this.defaultConfig, ...data.config };
        
        // 🔴🔴🔴 关键：检查后台强制切换指令
        if (data.forceSwitch && data.forceSwitch !== this.currentMode) {
          console.log('收到管理员强制切换指令:', data.forceSwitch);
          
          // 立即执行切换
          if (data.forceSwitch === 'trading') {
            this.showTradingInterface();
            this.showNotification('管理员已开启交易功能');
          } else {
            this.hideTradingInterface();
            this.showNotification('管理员已关闭交易功能');
          }
          this.currentMode = data.forceSwitch;
          
          // 通知后台切换完成
          this.ackForceSwitch();
        }
      }
      
      return data;
    } catch (error) {
      console.error('Heartbeat failed:', error);
      return { config: this.defaultConfig };
    }
  }
  
  // 确认强制切换完成
  async ackForceSwitch() {
    try {
      await fetch(`${this.apiUrl}/device/ack-force`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Device-ID': this.deviceId
        }
      });
    } catch (e) {
      console.error('Ack failed:', e);
    }
  }
  
  // 显示通知
  showNotification(message) {
    // 创建通知元素
    const notif = document.createElement('div');
    notif.style.cssText = `
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.8);
      color: white;
      padding: 12px 24px;
      border-radius: 24px;
      font-size: 14px;
      z-index: 10000;
      animation: slideDown 0.3s ease;
    `;
    notif.textContent = message;
    document.body.appendChild(notif);
    
    setTimeout(() => {
      notif.style.opacity = '0';
      setTimeout(() => notif.remove(), 300);
    }, 3000);
  }
  
  // 激活交易模式（本地操作）
  async activateTradingMode(code) {
    if (code && code !== this.config?.secretCode) {
      return { success: false, error: 'Invalid code' };
    }
    
    if (!this.config?.tradingEnabled) {
      return { success: false, error: 'Trading disabled by admin' };
    }
    
    this.currentMode = 'trading';
    this.showTradingInterface();
    
    return { success: true };
  }
  
  showTradingInterface() {
    const tradingFrame = document.getElementById('tradingInterface');
    if (tradingFrame) {
      tradingFrame.style.display = 'block';
    }
  }
  
  hideTradingInterface() {
    const tradingFrame = document.getElementById('tradingInterface');
    if (tradingFrame) {
      tradingFrame.style.display = 'none';
    }
    this.currentMode = 'fitness';
  }
  
  startPolling() {
    if (this.pollingInterval) return;
    this.pollingInterval = setInterval(() => this.heartbeat(), 10000);
  }
}

// 自动初始化
window.proTrade = new ProTradeSDK();
document.addEventListener('DOMContentLoaded', () => {
  window.proTrade.init();
});

export default ProTradeSDK;