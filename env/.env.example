# ============================================
# GigStream - 环境变量管理规范 (.env.example)
# ============================================
# 使用方式：
#   1. 复制本文件为 .env.local (开发) / .env.staging / .env.production
#   2. 移动端 (Expo) 变量必须以 EXPO_PUBLIC_ 开头，才能在构建时被注入
#   3. 后端变量直接读取 process.env
# ============================================

# --------------------------------------------
# 后端 - Cloud Run / Node.js
# --------------------------------------------
NODE_ENV=development
PORT=8080

# Firebase Admin SDK 配置（Cloud Run 使用）
# 方式A：通过 Secret Manager 挂载文件路径
FIREBASE_ADMIN_SDK_PATH=/secrets/firebase-admin-sdk.json
# 方式B：直接内嵌 JSON（仅本地调试，生产不推荐）
# FIREBASE_ADMIN_SDK_JSON={...}

# Firebase 项目 ID
FIREBASE_PROJECT_ID=gpt-jobs-dev

# API 基础配置
API_BASE_URL=http://localhost:8080
API_VERSION=v1

# Sentry DSN（错误监控，可选）
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Algolia 搜索（P1 阶段启用）
ALGOLIA_APP_ID=YOUR_ALGOLIA_APP_ID
ALGOLIA_API_KEY=YOUR_ALGOLIA_API_KEY
ALGOLIA_INDEX_NAME=jobs

# --------------------------------------------
# 移动端 - Expo / React Native
# --------------------------------------------
# API 地址（Expo 以 EXPO_PUBLIC_ 开头）
EXPO_PUBLIC_API_BASE_URL=https://api-staging-xxx.run.app/v1
EXPO_PUBLIC_FIREBASE_PROJECT_ID=gpt-jobs-dev

# Firebase Web 配置（Expo JS SDK 使用）
EXPO_PUBLIC_FIREBASE_API_KEY=AIza...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=gpt-jobs-dev.firebaseapp.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=gpt-jobs-dev.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:xxxx
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXX

# iOS / Android 应用 ID（EAS Submit 使用）
EXPO_PUBLIC_IOS_APP_ID=1234567890
EXPO_PUBLIC_ANDROID_PACKAGE=com.gptjobs.app

# --------------------------------------------
# CI/CD - GitHub Actions Secrets 清单
# --------------------------------------------
# 在 GitHub Repo → Settings → Secrets and variables → Actions 中配置：
#   GCP_SA_KEY                : GCP Service Account JSON (Base64 编码)
#   GCP_PROJECT_ID            : gcp-project-id
#   EXPO_TOKEN                : eas-cli 登录 Token (expo.dev/settings/access-tokens)
